redis: sh -c 'mkdir -p backend/storage/redis; if redis-cli -h 127.0.0.1 -p ${REDIS_PORT:-6380} ping >/dev/null 2>&1; then echo "Redis already running on 127.0.0.1:${REDIS_PORT:-6380}"; tail -f /dev/null; else exec redis-server --bind 127.0.0.1 --port ${REDIS_PORT:-6380} --save "" --appendonly no --dir backend/storage/redis; fi'
backend: sh -ec 'host="${APP_HOST:-localhost}"; port="${APP_PORT:-8000}"; if curl -fsS "http://$host:$port/health" >/dev/null 2>&1 || curl -fsS "http://$host:$port/healthz" >/dev/null 2>&1 || curl -fsS "http://$host:$port/docs" >/dev/null 2>&1; then echo "Backend already running on $host:$port"; exec tail -f /dev/null; fi; if [ "${RUN_MIGRATIONS:-1}" = "1" ]; then "${APP_PYTHON:-backend/.venv/bin/python}" -m alembic -c backend/alembic.ini upgrade head; fi; reload_args=""; if [ "${BACKEND_RELOAD:-0}" = "1" ]; then reload_args="--reload --reload-dir backend"; fi; exec "${APP_PYTHON:-backend/.venv/bin/python}" -m uvicorn backend.app.main:app $reload_args --host "$host" --port "$port"'
frontend: sh -c 'until curl -fsS "http://${APP_HOST:-localhost}:${APP_PORT:-8000}/health" >/dev/null 2>&1 || curl -fsS "http://${APP_HOST:-localhost}:${APP_PORT:-8000}/healthz" >/dev/null 2>&1 || curl -fsS "http://${APP_HOST:-localhost}:${APP_PORT:-8000}/docs" >/dev/null 2>&1; do echo "waiting for backend..."; sleep 1; done; cd frontend && exec npm run dev -- --host "${FRONTEND_HOST:-localhost}" --port "${FRONTEND_PORT:-5173}"'
browser: sh -c 'until curl -fsS "http://${APP_HOST:-localhost}:${APP_PORT:-8000}/health" >/dev/null 2>&1 || curl -fsS "http://${APP_HOST:-localhost}:${APP_PORT:-8000}/healthz" >/dev/null 2>&1 || curl -fsS "http://${APP_HOST:-localhost}:${APP_PORT:-8000}/docs" >/dev/null 2>&1; do echo "waiting for backend..."; sleep 1; done; until curl -fsS "http://${FRONTEND_HOST:-localhost}:${FRONTEND_PORT:-5173}" >/dev/null 2>&1; do echo "waiting for frontend..."; sleep 1; done; xdg-open "http://${FRONTEND_HOST:-localhost}:${FRONTEND_PORT:-5173}/dashboard?dev_ts=$(date +%s)" >/dev/null 2>&1 || true; tail -f /dev/null'
#llama_cpp: sh -ec 'host="${LLAMA_CPP_HOST:-127.0.0.1}"; port="${LLAMA_CPP_PORT:-8081}"; health_host="$host"; if [ "$health_host" = "0.0.0.0" ]; then health_host="127.0.0.1"; fi; if curl -fsS "http://$health_host:$port/v1/models" >/dev/null 2>&1; then echo "llama.cpp already running on $health_host:$port"; exec tail -f /dev/null; fi; bin="${LLAMA_CPP_BIN:-/home/polat/Desktop/Projects/llama.cpp/build/bin/llama-server}"; model="${LLAMA_CPP_MODEL:-/home/polat/Desktop/Projects/llama.cpp/models/Qwen_Qwen3-14B-Q4_K_M.gguf}"; test -x "$bin" || { echo "llama.cpp server binary is not executable: $bin"; exit 1; }; test -f "$model" || { echo "llama.cpp model not found: $model"; exit 1; }; exec "$bin" -m "$model" --host "$host" --port "$port" --ctx-size "${LLAMA_CPP_CTX:-4096}" --n-gpu-layers "${LLAMA_CPP_N_GPU_LAYERS:-35}" --parallel "${LLAMA_CPP_PARALLEL:-2}"'
ollama: sh -ec 'ollama_host="${OLLAMA_HOST:-127.0.0.1:11434}"; if curl -fsS "http://$ollama_host/api/tags" >/dev/null 2>&1; then echo "Ollama already running on $ollama_host"; exec tail -f /dev/null; fi; command -v ollama >/dev/null 2>&1 || { echo "ollama command not found. Install Ollama or run: make local-dev RUN_OLLAMA=0"; exit 1; }; exec env OLLAMA_HOST="$ollama_host" ollama serve'

# Background jobs use schedule_background + Redis locks (see core/background.py).
# Celery worker entrypoint removed until backend.entrypoints.workers exists.
